parm ../../stripped_trajectories/2KOCFolded_HRM_stripped.prmtop
trajin ../../stripped_trajectories/2KOCFolded_HRM_productionStripped.nc

autoimage :1-14

pucker U7 :7@C1' :7@C2' :7@C3' :7@C4' :7@O4' range360 out sugarPucker_U7.dat
pucker C8 :8@C1' :8@C2' :8@C3' :8@C4' :8@O4' range360 out sugarPucker_U7.dat

analyze statistics U7 out sugarPuckerStats_U7.dat
analyze statistics C8 out sugarPuckerStats_C8.dat

run
quit
